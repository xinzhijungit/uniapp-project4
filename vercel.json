{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "dist/build/h5/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "dist/build/h5/assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/build/h5/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/build/h5/index.html"
    }
  ]
}