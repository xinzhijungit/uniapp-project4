{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/build/h5/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/build/h5/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/build/h5/index.html"
    }
  ]
}
