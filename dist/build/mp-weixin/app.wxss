page{background-color:#f5f7fa;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica Neue,Arial,sans-serif;font-size:14px;color:#101010;line-height:1.5}.container{padding:24px;min-height:100vh;box-sizing:border-box}.card{background:#fff;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.06);padding:32px;margin-bottom:24px}.btn{display:flex;align-items:center;justify-content:center;height:88rpx;border-radius:4px;font-size:14px;font-weight:500;transition:all .3s ease;border:none}.btn-primary{background:linear-gradient(135deg,#0f40f5,#0a2b9b);color:#fff}.btn-primary:active{opacity:.85}.btn-secondary{background:#f5f5f5;color:#101010}.btn-secondary:active{background:#ededed}.btn-warning{background:#ff9800;color:#fff}.btn-danger{background:#f44336;color:#fff}.btn-small{height:64rpx;font-size:12px;padding:0 32px}.flex{display:flex}.flex-center{align-items:center;justify-content:center}.flex-between{align-items:center;justify-content:space-between}.flex-wrap{flex-wrap:wrap}.text-primary{color:#0f40f5}.text-success{color:#4caf50}.text-warning{color:#ff9800}.text-error{color:#f44336}.text-secondary{color:#666}.text-light{color:#bbb}.mt-xs{margin-top:8px}.mt-sm{margin-top:16px}.mt-md{margin-top:24px}.mt-lg{margin-top:32px}.mb-xs{margin-bottom:8px}.mb-sm{margin-bottom:16px}.mb-md{margin-bottom:24px}.mb-lg{margin-bottom:32px}.fs-xs{font-size:11px}.fs-sm{font-size:12px}.fs-base{font-size:14px}.fs-lg{font-size:16px}.fs-xl{font-size:18px}.fs-xxl{font-size:22px}.font-bold{font-weight:600}.tag{display:inline-flex;align-items:center;padding:4rpx 16rpx;border-radius:20rpx;font-size:11px}.tag-high{background:rgba(244,67,54,.1);color:#f44336}.tag-medium{background:rgba(255,152,0,.1);color:#ff9800}.tag-low{background:rgba(76,175,80,.1);color:#4caf50}.skeleton{background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0,#f0f0f0 75%);background-size:200% 100%;animation:skeleton-loading 1.5s ease-in-out infinite}@keyframes skeleton-loading{0%{background-position:200% 0}to{background-position:-200% 0}}
page::after{position:fixed;content:'';left:-1000px;top:-1000px;-webkit-animation:shadow-preload .1s;-webkit-animation-delay:3s;animation:shadow-preload .1s;animation-delay:3s}@-webkit-keyframes shadow-preload{0%{background-image:url(https://cdn1.dcloud.net.cn/img/shadow-grey.png)}100%{background-image:url(https://cdn1.dcloud.net.cn/img/shadow-grey.png)}}@keyframes shadow-preload{0%{background-image:url(https://cdn1.dcloud.net.cn/img/shadow-grey.png)}100%{background-image:url(https://cdn1.dcloud.net.cn/img/shadow-grey.png)}}page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}